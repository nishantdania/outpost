#!/usr/bin/env bash

set -euo pipefail

readonly OUTPOST_BIN_DIR="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")" && pwd)"
readonly OUTPOST_PATH="${OUTPOST_PATH:-$(cd -- "$OUTPOST_BIN_DIR/.." && pwd)}"
source "$OUTPOST_PATH/helpers/all.sh"

[ "$#" -ge 1 ] || {
    outpost_error "Usage: outpost-firecracker-ssh NAME [COMMAND...]"
    exit 2
}

readonly vm_name="$1"
readonly vm_dir="$OUTPOST_DEFAULT_VM_DIR/$vm_name"
readonly guest_ip_file="$vm_dir/ip"
shift

[ -f "$guest_ip_file" ] || {
    outpost_error "No network address found for Firecracker: $vm_name"
    exit 1
}
readonly guest_ip="$(< "$guest_ip_file")"

exec ssh \
    -i "$OUTPOST_DEFAULT_SSH_KEY" \
    -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null \
    "root@$guest_ip" \
    "$@"
