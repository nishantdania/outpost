#!/usr/bin/env bash

set -euo pipefail

readonly OUTPOST_BIN_DIR="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")" && pwd)"
readonly OUTPOST_PATH="${OUTPOST_PATH:-$(cd -- "$OUTPOST_BIN_DIR/.." && pwd)}"
source "$OUTPOST_PATH/helpers/all.sh"

[ "$#" -eq 1 ] || {
    outpost_error "Usage: outpost-firecracker-start NAME"
    exit 2
}

readonly vm_name="$1"
readonly vm_dir="$OUTPOST_DEFAULT_VM_DIR/$vm_name"
readonly rootfs="$vm_dir/rootfs.ext4"
readonly api_socket="$vm_dir/firecracker.socket"
readonly log_file="$vm_dir/firecracker.log"
readonly pid_file="$vm_dir/firecracker.pid"
readonly tap_file="$vm_dir/tap"
readonly vm_hash="$(printf '%s' "$vm_name" | sha256sum | cut -c1-10)"
readonly tap_name="op${vm_hash:0:8}"
readonly guest_mac="06:00:ac:10:00:02"
readonly uplink="$(ip route show default | awk 'NR==1 {print $5}')"

firecracker_api() {
    local resource="$1" payload="$2"

    curl --silent --show-error --fail \
        --unix-socket "$api_socket" \
        --request PUT \
        --header 'Content-Type: application/json' \
        --data "$payload" \
        "http://localhost/$resource"
}

mkdir -p "$vm_dir"
if [ ! -e "$rootfs" ]; then
    cp --reflink=auto "$OUTPOST_DEFAULT_ARCH_ROOTFS" "$rootfs"
fi

printf '%s\n' "$tap_name" > "$tap_file"
sudo ip tuntap add dev "$tap_name" mode tap user "$USER"
sudo ip addr add 172.16.0.1/30 dev "$tap_name"
sudo ip link set "$tap_name" up
sudo sysctl -w net.ipv4.ip_forward=1 >/dev/null
sudo nft delete table ip outpost 2>/dev/null || true
sudo nft -f - <<EOF
table ip outpost {
  chain forward { type filter hook forward priority filter; policy accept; }
  chain postrouting { type nat hook postrouting priority srcnat; ip saddr 172.16.0.2 oifname "$uplink" masquerade; }
}
EOF

rm -f "$api_socket"
: > "$log_file"
firecracker --enable-pci --api-sock "$api_socket" > "$log_file" 2>&1 &
readonly firecracker_pid=$!
printf '%s\n' "$firecracker_pid" > "$pid_file"

firecracker_api machine-config "{\"vcpu_count\": $OUTPOST_DEFAULT_VM_VCPU_COUNT, \"mem_size_mib\": $OUTPOST_DEFAULT_VM_MEMORY_MIB}"
firecracker_api boot-source "{\"kernel_image_path\": \"$OUTPOST_DEFAULT_IMAGE_DIR/vmlinux\", \"boot_args\": \"console=ttyS0 reboot=k panic=1 net.ifnames=0\"}"
firecracker_api drives/rootfs "{\"drive_id\": \"rootfs\", \"path_on_host\": \"$rootfs\", \"is_root_device\": true, \"is_read_only\": false}"
firecracker_api network-interfaces/eth0 "{\"iface_id\": \"eth0\", \"host_dev_name\": \"$tap_name\", \"guest_mac\": \"$guest_mac\"}"
firecracker_api actions '{"action_type":"InstanceStart"}'

outpost_info "Started Firecracker: $vm_name"
outpost_info "Log: $log_file"
